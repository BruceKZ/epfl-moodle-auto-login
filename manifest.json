{
  "manifest_version": 3,
  "name": "EPFL Moodle Auto Login",
  "version": "1.0.0",
  "description": "Automatically starts EPFL Moodle login and selects the first remembered EPFL account on Microsoft Entra pages.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://moodle.epfl.ch/*",
    "https://login.microsoftonline.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://moodle.epfl.ch/*"
      ],
      "js": [
        "src/moodle.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://login.microsoftonline.com/*"
      ],
      "js": [
        "src/entra.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "action": {
    "default_title": "EPFL Moodle Auto Login"
  }
}
